{
  "name": "ts-contractbridge",
  "version": "0.1.0",
  "description": "A TypeScript library for contract bridge",
  "keywords": ["bridge", "contract-bridge", "cards", "game"],
  "license": "MIT",

  "type": "module",

  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],

  "scripts": {
    "build":        "tsc --project tsconfig.json",
    "build:watch":  "tsc --project tsconfig.json --watch",
    "test":         "vitest run",
    "test:watch":   "vitest",
    "test:coverage":"vitest run --coverage",
    "typecheck":    "tsc --noEmit",
    "clean":        "rm -rf dist"
  },

  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.8",
    "tsx": "^4.19.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
